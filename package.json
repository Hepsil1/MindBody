    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@vercel/react-router": "^1.2.5",
    "isbot": "^5.1.31",
    "prisma": "^5.22.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
