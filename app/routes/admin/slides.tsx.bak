import { useState } from "react";
import { useLoaderData, useFetcher, Form } from "react-router";
import type { Route } from "./+types/slides";
import { prisma } from "../../db.server";

export async function loader({ request }: Route.LoaderArgs) {
    const slides = await prisma.slide.findMany({
        orderBy: { order: "asc" },
    });
    return { slides };
}

export async function action({ request }: Route.ActionArgs) {
    const formData = await request.formData();
    const intent = formData.get("intent");

    if (intent === "create") {
        const name = formData.get("name") as string;
        const type = formData.get("type") as string;
        const link = formData.get("link") as string;
        const image1 = formData.get("image1") as string;
        const image2 = formData.get("image2") as string;
        const image3 = formData.get("image3") as string;

        const maxOrder = await prisma.slide.aggregate({ _max: { order: true } });
        const newOrder = (maxOrder._max.order || 0) + 1;

        await prisma.slide.create({
            data: {
                name,
                type,
                link: link || null,
                image1,
                image2: image2 || null,
                image3: image3 || null,
                order: newOrder,
            },
        });
        return { success: true };
    }

    if (intent === "delete") {
        const id = formData.get("id") as string;
        await prisma.slide.delete({ where: { id } });
        return { success: true };
    }

    if (intent === "reorder") {
        const id = formData.get("id") as string;
        const direction = formData.get("direction") as string;
        const slide = await prisma.slide.findUnique({ where: { id } });
        if (!slide) return { error: "Slide not found" };

        const targetOrder = direction === "up" ? slide.order - 1 : slide.order + 1;
        const swapSlide = await prisma.slide.findFirst({ where: { order: targetOrder } });

        if (swapSlide) {
            await prisma.$transaction([
                prisma.slide.update({ where: { id: slide.id }, data: { order: targetOrder } }),
                prisma.slide.update({ where: { id: swapSlide.id }, data: { order: slide.order } }),
            ]);
        }
        return { success: true };
    }

    return { error: "Unknown intent" };
}

// Icons
const TrashIcon = () => (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" width="18" height="18">
        <path d="M3 6h18M8 6V4a2 2 0 012-2h4a2 2 0 012 2v2m3 0v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6h14z" />
    </svg>
);

const ChevronDown = () => (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" width="16" height="16">
        <path d="M6 9l6 6 6-6" />
    </svg>
);

export default function AdminSlides() {
    const { slides } = useLoaderData<typeof loader>();
    const fetcher = useFetcher();
    const [slideType, setSlideType] = useState<"triptych" | "single">("triptych");

    const handleDelete = (id: string) => {
        if (confirm("Ви впевнені, що хочете видалити цей слайд?")) {
            fetcher.submit({ intent: "delete", id }, { method: "post" });
        }
    };

    const handleReorder = (id: string, direction: "up" | "down") => {
        fetcher.submit({ intent: "reorder", id, direction }, { method: "post" });
    };

    return (
        <>
            <div className="admin-page-header">
                <h1>Управління слайдами</h1>
                <p>Налаштуйте слайди для головної сторінки</p>
            </div>

            <div className="admin-card" style={{ marginBottom: "32px" }}>
                <div style={{
                    padding: "20px 24px",
                    borderBottom: "1px solid var(--border-subtle)",
                    display: "flex",
                    justifyContent: "space-between",
                    alignItems: "center"
                }}>
                    <h3 style={{ margin: 0, fontSize: "14px", textTransform: "uppercase", letterSpacing: "1px", color: "var(--text-muted)" }}>
                        Активні слайди ({slides.length})
                    </h3>
                </div>

                <div style={{ padding: "16px 24px" }}>
                    {slides.length === 0 ? (
                        <p style={{ color: "var(--text-muted)", textAlign: "center", padding: "40px 0" }}>
                            Слайдів ще немає. Додайте перший слайд нижче.
                        </p>
                    ) : (
                        <div style={{ display: "flex", flexDirection: "column", gap: "12px" }}>
                            {slides.map((slide, index) => (
                                <div
                                    key={slide.id}
                                    style={{
                                        display: "flex",
                                        alignItems: "center",
                                        gap: "16px",
                                        padding: "12px 16px",
                                        background: "var(--bg-elevated)",
                                        borderRadius: "8px",
                                        border: "1px solid var(--border-subtle)",
                                    }}
                                >
                                    {/* Thumbnail */}
                                    <div style={{
                                        width: "60px",
                                        height: "60px",
                                        borderRadius: "6px",
                                        overflow: "hidden",
                                        background: "var(--bg-recessed)",
                                        flexShrink: 0,
                                    }}>
                                        <img
                                            src={slide.image1}
                                            alt={slide.name}
                                            style={{ width: "100%", height: "100%", objectFit: "cover" }}
                                            onError={(e) => { (e.target as HTMLImageElement).style.display = "none"; }}
                                        />
                                    </div>

                                    {/* Info */}
                                    <div style={{ flex: 1 }}>
                                        <div style={{ fontWeight: 600, color: "var(--text-main)", marginBottom: "4px" }}>
                                            {slide.name}
                                        </div>
                                        <div style={{ fontSize: "13px", color: "var(--text-muted)" }}>
                                            {slide.type === "triptych" ? "3 фото (триптих)" : "1 фото (full)"}
                                        </div>
                                    </div>

                                    {/* Actions */}
                                    <div style={{ display: "flex", gap: "8px", alignItems: "center" }}>
                                        <button
                                            onClick={() => handleReorder(slide.id, "down")}
                                            disabled={index === slides.length - 1}
                                            style={{
                                                background: "none",
                                                border: "none",
                                                color: "var(--accent-primary)",
                                                cursor: index === slides.length - 1 ? "not-allowed" : "pointer",
                                                opacity: index === slides.length - 1 ? 0.3 : 1,
                                                padding: "8px",
                                            }}
                                            title="Перемістити вниз"
                                        >
                                            <ChevronDown />
                                        </button>
                                        <button
                                            onClick={() => handleDelete(slide.id)}
                                            style={{
                                                background: "rgba(255, 100, 100, 0.1)",
                                                border: "none",
                                                color: "#ff6b6b",
                                                cursor: "pointer",
                                                padding: "8px",
                                                borderRadius: "6px",
                                            }}
                                            title="Видалити"
                                        >
                                            <TrashIcon />
                                        </button>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            </div>

            {/* Add New Slide Form */}
            <div className="admin-card">
                <div style={{
                    padding: "20px 24px",
                    borderBottom: "1px solid var(--border-subtle)"
                }}>
                    <h3 style={{ margin: 0, fontSize: "14px", textTransform: "uppercase", letterSpacing: "1px", color: "var(--accent-primary)" }}>
                        + Додати новий слайд
                    </h3>
                </div>

                <Form method="post" style={{ padding: "24px" }}>
                    <input type="hidden" name="intent" value="create" />

                    {/* Slide Type */}
                    <div style={{ marginBottom: "24px" }}>
                        <div style={{ display: "flex", gap: "24px" }}>
                            <label style={{ display: "flex", alignItems: "center", gap: "8px", cursor: "pointer" }}>
                                <input
                                    type="radio"
                                    name="type"
                                    value="triptych"
                                    checked={slideType === "triptych"}
                                    onChange={() => setSlideType("triptych")}
                                    style={{ accentColor: "var(--accent-primary)" }}
                                />
                                <span style={{ color: "var(--text-main)" }}>Триптих (3 фото)</span>
                            </label>
                            <label style={{ display: "flex", alignItems: "center", gap: "8px", cursor: "pointer" }}>
                                <input
                                    type="radio"
                                    name="type"
                                    value="single"
                                    checked={slideType === "single"}
                                    onChange={() => setSlideType("single")}
                                    style={{ accentColor: "var(--accent-primary)" }}
                                />
                                <span style={{ color: "var(--text-main)" }}>Одне фото (Full)</span>
                            </label>
                        </div>
                    </div>

                    {/* Name */}
                    <div style={{ marginBottom: "20px" }}>
                        <label style={{ display: "block", marginBottom: "8px", color: "var(--text-muted)", fontSize: "13px" }}>
                            Назва слайду
                        </label>
                        <input
                            type="text"
                            name="name"
                            required
                            placeholder="Наприклад: Teal Collection"
                            className="admin-input"
                            style={{ width: "100%", padding: "12px 16px", background: "var(--bg-recessed)", border: "1px solid var(--border-subtle)", borderRadius: "8px", color: "var(--text-main)" }}
                        />
                    </div>

                    {/* Link */}
                    <div style={{ marginBottom: "20px" }}>
                        <label style={{ display: "block", marginBottom: "8px", color: "var(--text-muted)", fontSize: "13px" }}>
                            Посилання (необов'язково)
                        </label>
                        <input
                            type="text"
                            name="link"
                            placeholder="/shop/women"
                            className="admin-input"
                            style={{ width: "100%", padding: "12px 16px", background: "var(--bg-recessed)", border: "1px solid var(--border-subtle)", borderRadius: "8px", color: "var(--text-main)" }}
                        />
                    </div>

                    {/* Images */}
                    <div style={{ marginBottom: "24px" }}>
                        <label style={{ display: "block", marginBottom: "8px", color: "var(--text-muted)", fontSize: "13px" }}>
                            Головне фото (обов'язково)
                        </label>
                        <input
                            type="text"
                            name="image1"
                            required
                            placeholder="/generalpics/333_131123.jpg"
                            className="admin-input"
                            style={{ width: "100%", padding: "12px 16px", background: "var(--bg-recessed)", border: "1px solid var(--border-subtle)", borderRadius: "8px", color: "var(--text-main)" }}
                        />
                    </div>

                    {slideType === "triptych" && (
                        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "24px" }}>
                            <div>
                                <label style={{ display: "block", marginBottom: "8px", color: "var(--text-muted)", fontSize: "13px" }}>
                                    Фото 2 (центр)
                                </label>
                                <input
                                    type="text"
                                    name="image2"
                                    placeholder="/generalpics/374_131123.jpg"
                                    className="admin-input"
                                    style={{ width: "100%", padding: "12px 16px", background: "var(--bg-recessed)", border: "1px solid var(--border-subtle)", borderRadius: "8px", color: "var(--text-main)" }}
                                />
                            </div>
                            <div>
                                <label style={{ display: "block", marginBottom: "8px", color: "var(--text-muted)", fontSize: "13px" }}>
                                    Фото 3 (праворуч)
                                </label>
                                <input
                                    type="text"
                                    name="image3"
                                    placeholder="/generalpics/338_131123.jpg"
                                    className="admin-input"
                                    style={{ width: "100%", padding: "12px 16px", background: "var(--bg-recessed)", border: "1px solid var(--border-subtle)", borderRadius: "8px", color: "var(--text-main)" }}
                                />
                            </div>
                        </div>
                    )}

                    <button
                        type="submit"
                        style={{
                            width: "100%",
                            padding: "16px 24px",
                            background: "var(--accent-primary)",
                            color: "var(--bg-base)",
                            border: "none",
                            borderRadius: "8px",
                            fontSize: "15px",
                            fontWeight: 600,
                            cursor: "pointer",
                            transition: "all 0.2s ease",
                        }}
                    >
                        Створити слайд
                    </button>
                </Form>
            </div>
        </>
    );
}
